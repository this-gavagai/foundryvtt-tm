# Relay secrets config. Copy this OUTSIDE the repo and fill it in:
#   mkdir -p ~/.config/tablemate-push-relay
#   cp relay.env.example ~/.config/tablemate-push-relay/relay.env
# Then run: npm run secrets
#
# This file (relay.env.example) contains only placeholders and is safe to commit.
# The real relay.env and the .p8 it points to live outside the repo.

# From the APNs auth key you created in Apple Developer > Keys (10 chars).
APNS_KEY_ID=XXXXXXXXXX

# Your Apple Team ID — the same value as fastlane's IOS_DEVELOPMENT_TEAM.
APNS_TEAM_ID=329R5JWLNS

# Path to the APNs .p8, kept outside the repo alongside your other keys.
# This is a NEW key (APNs), distinct from the App Store Connect API key.
APNS_KEY_FILE=/Users/petergraif/.config/apns/tablemate/AuthKey_XXXXXXXXXX.p8

# For CI where there's no file on disk, base64 the .p8 into this instead and
# leave APNS_KEY_FILE unset (mirrors APP_STORE_CONNECT_KEY_CONTENT):
#   base64 -i AuthKey_XXXXXXXXXX.p8 | pbcopy
# APNS_KEY_CONTENT=

# Any long random string; the same value goes in your curl Authorization header.
RELAY_TEST_SECRET=change-me-to-a-long-random-string
