{
  "name": "tm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "live": "NODE_ENV=development vite build --watch --mode development",
    "hot": "run-p dev live",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:foundry": "run-p type-check \"build-only {@}\" --",
    "build:native": "run-s type-check build-native-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "build-native-only": "vite build --mode capacitor",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "run-s build:native cap:sync-only",
    "cap:sync-only": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/3d-meeple.svg"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@systemic-games/pixels-web-connect": "^1.3.1",
    "@vueuse/core": "^11.3.0",
    "lodash-es": "^4.17.21",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.4"
  },
  "devDependencies": {
    "@7h3laughingman/foundry-types": "^13.351.20",
    "@7h3laughingman/pf2e-types": "^7.10.4",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@headlessui/tailwindcss": "^0.2.2",
    "@tailwindcss/postcss": "^4.1.5",
    "@tsconfig/node22": "^22.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.9.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.15.0",
    "eslint-formatter-summary": "^2.0.2",
    "eslint-plugin-vue": "^9.31.0",
    "globals": "^15.12.0",
    "npm-run-all2": "^7.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-classnames": "^0.7.4",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.16.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vue-tsc": "^2.1.10"
  },
  "overrides": {
    "@headlessui/tailwindcss": {
      "tailwindcss": "$tailwindcss"
    }
  }
}
