default_platform(:ios)

private_lane :sync_capacitor do
  sh("npm run cap:sync")
end

private_lane :apple_team_id do
  team_id = ENV["IOS_DEVELOPMENT_TEAM"]
  UI.user_error!("Set IOS_DEVELOPMENT_TEAM to your Apple development team ID before running this lane.") if team_id.to_s.empty?

  team_id
end

private_lane :app_store_connect_key do
  key_id = ENV["APP_STORE_CONNECT_KEY_ID"]
  issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
  key_content = ENV["APP_STORE_CONNECT_KEY_CONTENT"]
  key_filepath = ENV["APP_STORE_CONNECT_KEY_FILE"]

  UI.user_error!("Set APP_STORE_CONNECT_KEY_ID before running this lane.") if key_id.to_s.empty?
  UI.user_error!("Set APP_STORE_CONNECT_ISSUER_ID before running this lane.") if issuer_id.to_s.empty?

  # Prefer the inline (base64) key on CI, where there is no .p8 file on disk;
  # fall back to the local file path for developer machines.
  if !key_content.to_s.empty?
    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      is_key_content_base64: true
    )
  elsif !key_filepath.to_s.empty?
    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_filepath
    )
  else
    UI.user_error!("Set APP_STORE_CONNECT_KEY_FILE (local .p8 path) or APP_STORE_CONNECT_KEY_CONTENT (base64 .p8 for CI) before running this lane.")
  end
end

platform :ios do
  desc "Create (or download) the Apple Distribution certificate and export a .p12"
  desc "for the IOS_DIST_CERT_BASE64 GitHub secret. Run once, then export/encode the"
  desc "result. Pass an output dir + password, e.g.:"
  desc "  bundle exec fastlane ios certificates dist_cert_password:hunter2"
  lane :certificates do |options|
    api_key = app_store_connect_key
    output_path = options[:output_path] || "fastlane/certs"
    password = options[:dist_cert_password]
    UI.user_error!("Pass dist_cert_password:<password> to protect the exported .p12.") if password.to_s.empty?

    get_certificates(
      api_key: api_key,
      type: "distribution",
      output_path: output_path,
      generate_apple_certs: true
    )

    cert_id = lane_context[SharedValues::CERT_CERTIFICATE_ID]
    cer = File.join(output_path, "#{cert_id}.cer")        # certificate (DER)
    key_pem = File.join(output_path, "#{cert_id}.p12")    # private key (PEM, despite the extension)
    cert_pem = File.join(output_path, "#{cert_id}.pem")
    p12 = File.join(output_path, "dist.p12")

    # Bundle the cert + private key into one password-protected PKCS#12 for the
    # IOS_DIST_CERT_BASE64 secret. Pass the password via env so it never lands in
    # the process list. -legacy keeps it importable by macOS `security`.
    ENV["TM_P12_PASS"] = password
    sh("openssl", "x509", "-inform", "der", "-in", cer, "-out", cert_pem)
    sh("openssl", "pkcs12", "-export", "-legacy", "-inkey", key_pem, "-in", cert_pem, "-out", p12, "-passout", "env:TM_P12_PASS")

    UI.success("Distribution .p12 written to #{p12}")
    UI.important("Add these GitHub secrets, then delete #{output_path}:")
    UI.message("  IOS_DIST_CERT_BASE64    = output of:  base64 -i #{p12}")
    UI.message("  IOS_DIST_CERT_PASSWORD  = #{password}")
  end

  desc "Build a signed iOS release IPA from the Capacitor app"
  lane :build do
    sync_capacitor

    team_id = apple_team_id

    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "development",
      clean: true,
      export_team_id: team_id,
      output_directory: "build",
      xcargs: "DEVELOPMENT_TEAM=#{team_id}"
    )
  end

  desc "Build an App Store IPA and upload it to TestFlight"
  lane :beta do
    sync_capacitor

    team_id = apple_team_id
    api_key = app_store_connect_key

    version_number = get_version_number(
      xcodeproj: "ios/App/App.xcodeproj",
      target: "App",
      configuration: "Release"
    )
    local_build_number = get_build_number(
      xcodeproj: "ios/App/App.xcodeproj"
    ).to_i
    latest_build = latest_testflight_build_number(
      api_key: api_key,
      version: version_number,
      initial_build_number: 0
    ).to_s
    # TestFlight may already hold an integer release build ("108") or a local
    # tuple build ("108.2"); split it into major/minor for comparison.
    latest_major = latest_build.split(".")[0].to_i
    latest_minor = latest_build.split(".")[1].to_i

    release_tag = ENV["APP_VERSION"].to_s.strip
    tag_digits = release_tag.gsub(/\D/, "")

    if tag_digits.empty?
      # Local / manual build: append a minor component (108 -> 108.1, 108.1 ->
      # 108.2). The tuple sorts above the current build but stays below the next
      # integer, so ad-hoc builds never claim the number a tagged release will use.
      major = [latest_major, local_build_number].max
      next_build_number = "#{major}.#{latest_minor + 1}"
    else
      # Tagged release build (from CI): the integer digits of the tag become the
      # build number (alpha-0108 -> 108). Guard against going backwards relative
      # to anything already on TestFlight or in the project.
      release_number = tag_digits.to_i
      release_number = latest_major + 1 if release_number <= latest_major
      release_number = local_build_number if local_build_number > release_number
      next_build_number = release_number.to_s
      if release_number != tag_digits.to_i
        UI.important("Tag build number #{tag_digits.to_i} is not ahead of existing builds; using #{next_build_number} instead.")
      end
    end

    app_identifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)

    if ENV["CI"].to_s.casecmp("true").zero?
      # On CI there is no signed-in Xcode account, so automatic signing can't
      # talk to the developer portal. Download an App Store profile with the API
      # key and switch the project to manual signing against the distribution
      # certificate that was imported into the temporary keychain.
      get_provisioning_profile(
        api_key: api_key,
        app_identifier: app_identifier,
        readonly: false
      )
      profile_name = lane_context[SharedValues::SIGH_NAME]

      update_code_signing_settings(
        path: "ios/App/App.xcodeproj",
        use_automatic_signing: false,
        team_id: team_id,
        code_sign_identity: "Apple Distribution",
        profile_name: profile_name,
        targets: ["App"]
      )

      ipa_path = build_app(
        project: "ios/App/App.xcodeproj",
        scheme: "App",
        configuration: "Release",
        export_method: "app-store",
        clean: true,
        export_team_id: team_id,
        output_directory: "build",
        xcargs: "CURRENT_PROJECT_VERSION=#{next_build_number}",
        export_options: {
          signingStyle: "manual",
          provisioningProfiles: { app_identifier => profile_name }
        }
      )
    else
      # Local developer machine: rely on the automatic signing already
      # configured in Xcode, letting it manage the provisioning profile.
      ipa_path = build_app(
        project: "ios/App/App.xcodeproj",
        scheme: "App",
        configuration: "Release",
        export_method: "app-store",
        clean: true,
        export_team_id: team_id,
        output_directory: "build",
        xcargs: "DEVELOPMENT_TEAM=#{team_id} CURRENT_PROJECT_VERSION=#{next_build_number} -allowProvisioningUpdates"
      )
    end
    ipa_build_number = get_ipa_info_plist_value(
      ipa: ipa_path,
      key: "CFBundleVersion"
    )
    UI.user_error!("Expected IPA build #{next_build_number}, got #{ipa_build_number}") unless ipa_build_number.to_s == next_build_number.to_s

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      changelog: release_tag.empty? ? nil : "TableMate #{release_tag} (build #{next_build_number})",
      skip_waiting_for_build_processing: true
    )
  end
end

platform :android do
  desc "Build a local Android release APK from the Capacitor app"
  lane :build do
    sync_capacitor

    gradle(
      project_dir: "android",
      task: "assemble",
      build_type: "Release"
    )
  end

  desc "Build an Android release AAB for signing and Play Console upload"
  lane :bundle do
    sync_capacitor

    gradle(
      project_dir: "android",
      task: "bundle",
      build_type: "Release"
    )
  end
end
